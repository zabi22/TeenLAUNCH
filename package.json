{
  "name": "teenlaunch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "worker": "tsx src/worker.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild src/worker.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/worker.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx run_migration.ts",
    "db:generate": "drizzle-kit generate --config=src/db/drizzle.config.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bullmq": "^5.79.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cache": "^5.1.2",
    "pg": "^8.22.0",
    "puppeteer": "^25.2.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.14.0",
    "@types/node-cache": "^4.1.3",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "google-auth-library": "^10.9.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
